# Variables usadas por el backend. NO poner secretos reales aquí.
# FIREBASE_CREDENTIALS: JSON string del service account (omitir private_key aquí o dejar <REDACTED>)
FIREBASE_CREDENTIALS='{"type":"service_account","project_id":"<PROJECT_ID>","client_email":"<CLIENT_EMAIL>"}'
# IDs de hojas de Google Sheets
GOOGLE_SHEET_ID=<GOOGLE_SHEET_ID>
GOOGLE_SHEET_PADRON_ID=<GOOGLE_SHEET_PADRON_ID>
GOOGLE_SHEET_CLASICO_ID=<GOOGLE_SHEET_CLASICO_ID>
# Secreto JWT (generar en producción)
JWT_SECRET=<RANDOM_SECRET>